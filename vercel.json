{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://thecapitalbridge.com https://www.thecapitalbridge.com"
        }
      ]
    }
  ]
}
